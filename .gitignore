# OpenSCAD render/build output
.renders/
*.stl
*.3mf
*.amf
*.csg
*.echo
*.png

# ...except reference scans of the original designs, and the browser
# preview's pre-generated plates (real deliverables, not build scratch)
!designs/**/reference/*.stl
!designs/**/preview/pregen/*.stl
!designs/**/preview/pregen/*.3mf

.DS_Store
